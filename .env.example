# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Payment bypass (server-only). Mirror token in URL: /onboard?bypass=YOUR_SECRET
BYPASS_SECRET=
# Comma-separated admin emails (dashboard + onboard admin actions)
ADMIN_EMAILS=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (fallback when Anthropic quota exhausted)
OPENAI_API_KEY=your_openai_api_key

# LLM fallback chain (OpenAI → Gemini → optional DeepSeek) after Anthropic/OpenAI primary failures
# Used by commentary routes, NativityAgent, ForecastAgent, generateAstrologyAnalysis
LLM_FALLBACK_OPENAI_MODEL=gpt-4o
LLM_FALLBACK_GEMINI_MODEL=gemini-2.0-flash
# Optional third tier (requires DEEPSEEK_API_KEY)
LLM_FALLBACK_DEEPSEEK_ENABLED=false
LLM_FALLBACK_DEEPSEEK_MODEL=deepseek-chat

# Gemini (fallback tier and model_override gemini-*)
GEMINI_API_KEY=

# DeepSeek (model_override deepseek-* and optional fallback when enabled above)
DEEPSEEK_API_KEY=

# Ephemeris service (Railway URL after deploy)
EPHEMERIS_SERVICE_URL=https://your-service.up.railway.app

# Validation skip (set to true on Vercel until generation time is stable)
NEXT_PUBLIC_SKIP_VALIDATION=true

# App
NEXT_PUBLIC_URL=http://localhost:3000
