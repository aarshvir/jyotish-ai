# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Payment bypass (server-only). Mirror token in URL: /onboard?bypass=YOUR_SECRET
BYPASS_SECRET=
# Comma-separated admin emails (dashboard + onboard admin actions)
ADMIN_EMAILS=

# Ziina (payments)
# Server-side token — obtain from https://business.ziina.com → Settings → Developers → API Keys
#
# Individual / API-only plan (no merchant webhooks):
#   - Set only ZIINA_API_TOKEN. Do NOT register a webhook URL in Ziina.
#   - Checkout success/failure still hits GET /api/ziina/verify (redirect URLs on each intent).
#   - Users who close the tab before redirect may need to re-open the app or run payment
#     recovery from the dashboard (no server push without a Business webhook).
#
# Business plan (optional webhooks):
#   - Set ZIINA_WEBHOOK_SECRET and register POST https://<your-domain>/api/ziina/webhook
#   - HMAC on raw JSON body, header X-Hmac-Signature
ZIINA_API_TOKEN=your_ziina_api_token
ZIINA_WEBHOOK_SECRET=
# Set true to reject webhook requests not from Ziina published IPs (can break tunnels)
ZIINA_WEBHOOK_ENFORCE_IP=false
# Set to false to disable post-7-day upgrade upsell redirect and /upsell
UPSELL_ENABLED=true

# Inngest (background DAG for report generation)
# Create workspace at https://www.inngest.com → Manage → Event Keys / Signing Keys
INNGEST_EVENT_KEY=your_inngest_event_key
INNGEST_SIGNING_KEY=your_inngest_signing_key

# Internal job auth (server-only): signs x-job-token for Inngest → API calls.
# Must be long, random, and not NEXT_PUBLIC_. If omitted, the app falls back to
# SUPABASE_SERVICE_ROLE_KEY for compatibility, but a dedicated secret is preferred.
JOB_TOKEN_SECRET=

# Upstash Redis (server-only): global rate limits, report-start locks, and shared caches.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI (fallback when Anthropic quota exhausted)
OPENAI_API_KEY=your_openai_api_key

# LLM fallback chain (OpenAI → Gemini → optional DeepSeek) after Anthropic/OpenAI primary failures
# Used by commentary routes, NativityAgent, ForecastAgent, generateAstrologyAnalysis
LLM_FALLBACK_OPENAI_MODEL=gpt-5.5
LLM_FALLBACK_GEMINI_MODEL=gemini-2.0-flash
# Optional third tier (requires DEEPSEEK_API_KEY)
LLM_FALLBACK_DEEPSEEK_ENABLED=false
LLM_FALLBACK_DEEPSEEK_MODEL=deepseek-chat

# Gemini (fallback tier and model_override gemini-*)
GEMINI_API_KEY=

# DeepSeek (model_override deepseek-* and optional fallback when enabled above)
DEEPSEEK_API_KEY=

# Ephemeris service (Railway URL after deploy)
EPHEMERIS_SERVICE_URL=https://your-service.up.railway.app

# Validation skip (set to true on Vercel until generation time is stable)
NEXT_PUBLIC_SKIP_VALIDATION=true

# App
NEXT_PUBLIC_URL=http://localhost:3000

# Optional: protect /api/cron/refresh-embeddings with Authorization: Bearer <secret>
CRON_SECRET=

# Trusted Web Activity (Play Store) — /.well-known/assetlinks.json (rewrite → API)
# 1) Deploy; open /manifest.webmanifest and /.well-known/assetlinks.json in a browser.
# 2) npx @bubblewrap/cli init --manifest https://YOUR_DOMAIN/manifest.webmanifest
# 3) bubblewrap build; upload app-release-bundle.aab to Play Console (internal testing first).
# 4) Play Console → App signing: copy SHA-256 certificate fingerprint; set env below; redeploy.
# Fingerprints: colon-separated hex (e.g. AB:CD:...), multiple comma- or space-separated.
ANDROID_TWA_PACKAGE_NAME=com.vedichour.app
ANDROID_TWA_SHA256_FINGERPRINTS=
